# External PostgreSQL credentials
# Create these databases and users on your own Postgres instance, then copy this file to .env

# IAM database
IAM_DATABASE_HOST=localhost
IAM_DATABASE_PORT=5432
IAM_DATABASE_USER=iam_user
IAM_DATABASE_PASSWORD=iam-password
IAM_DATABASE_NAME=iam
IAM_DATABASE_SSLMODE=disable

# Hydra database
HYDRA_DATABASE_HOST=localhost
HYDRA_DATABASE_PORT=5432
HYDRA_DATABASE_USER=hydra_user
HYDRA_DATABASE_PASSWORD=hydra-password
HYDRA_DATABASE_NAME=hydra
HYDRA_DATABASE_SSLMODE=disable

# Auth gateway introspection client (must match Hydra client created by hydra-seed job)
INTROSPECTION_CLIENT_ID=auth-gateway
INTROSPECTION_CLIENT_SECRET=auth-gateway-secret

# Mock token dev secret
JWT_SECRET=super-secret-dev-key-change-in-production

# Redis URL override (leave empty to use in-memory session store locally)
REDIS_URL=
