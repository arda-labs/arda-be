<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" id="Definitions_CustomerAdjustmentV1" targetNamespace="https://arda.io.vn/bpmn/customer" exporter="Arda" exporterVersion="1.0">
  <bpmn:process id="customer-adjustment-v1" name="Điều chỉnh hồ sơ khách hàng" isExecutable="true">
    <bpmn:startEvent id="StartEvent_Submitted" name="Gửi điều chỉnh">
      <bpmn:outgoing>Flow_Start_CheckerReview</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:serviceTask id="Activity_CheckerReview" name="Kiểm soát điều chỉnh hồ sơ">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="workflow.customer_checker_review" />
        <zeebe:taskHeaders>
          <zeebe:header key="candidateRole" value="CUSTOMER_CHECKER" />
          <zeebe:header key="formKey" value="customer-adjustment-review" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Start_CheckerReview</bpmn:incoming>
      <bpmn:incoming>Flow_RevisionBack_Review</bpmn:incoming>
      <bpmn:outgoing>Flow_Review_DecisionGateway</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:exclusiveGateway id="Gateway_CheckerDecision" name="Quyết định kiểm soát">
      <bpmn:incoming>Flow_Review_DecisionGateway</bpmn:incoming>
      <bpmn:outgoing>Flow_Decision_RequestChanges</bpmn:outgoing>
      <bpmn:outgoing>Flow_Decision_Reject</bpmn:outgoing>
      <bpmn:outgoing>Flow_Decision_Approve</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:serviceTask id="Activity_RequestChanges" name="Yêu cầu bổ sung điều chỉnh">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="crm.request_customer_changes" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Decision_RequestChanges</bpmn:incoming>
      <bpmn:outgoing>Flow_RequestChanges_Revise</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="Activity_MakerRevise" name="Maker bổ sung điều chỉnh">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="workflow.customer_maker_revise" />
        <zeebe:taskHeaders>
          <zeebe:header key="candidateRole" value="CUSTOMER_MAKER" />
          <zeebe:header key="formKey" value="customer-adjustment-revise" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_RequestChanges_Revise</bpmn:incoming>
      <bpmn:outgoing>Flow_RevisionBack_Review</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="Activity_RejectAdjustment" name="Từ chối điều chỉnh">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="crm.reject_customer" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Decision_Reject</bpmn:incoming>
      <bpmn:outgoing>Flow_Reject_End</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="Activity_ApplyAdjustment" name="Áp dụng điều chỉnh hồ sơ">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="crm.approve_customer" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Decision_Approve</bpmn:incoming>
      <bpmn:outgoing>Flow_Approve_End</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="EndEvent_Applied" name="Điều chỉnh được duyệt">
      <bpmn:incoming>Flow_Approve_End</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_Rejected" name="Điều chỉnh bị từ chối">
      <bpmn:incoming>Flow_Reject_End</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_Start_CheckerReview" sourceRef="StartEvent_Submitted" targetRef="Activity_CheckerReview" />
    <bpmn:sequenceFlow id="Flow_Review_DecisionGateway" sourceRef="Activity_CheckerReview" targetRef="Gateway_CheckerDecision" />
    <bpmn:sequenceFlow id="Flow_Decision_RequestChanges" name="Bổ sung" sourceRef="Gateway_CheckerDecision" targetRef="Activity_RequestChanges">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=reviewDecision = "REQUEST_CHANGES"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Decision_Reject" name="Từ chối" sourceRef="Gateway_CheckerDecision" targetRef="Activity_RejectAdjustment">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=reviewDecision = "REJECT"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Decision_Approve" name="Duyệt" sourceRef="Gateway_CheckerDecision" targetRef="Activity_ApplyAdjustment">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=reviewDecision = "APPROVE"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_RequestChanges_Revise" sourceRef="Activity_RequestChanges" targetRef="Activity_MakerRevise" />
    <bpmn:sequenceFlow id="Flow_RevisionBack_Review" sourceRef="Activity_MakerRevise" targetRef="Activity_CheckerReview" />
    <bpmn:sequenceFlow id="Flow_Reject_End" sourceRef="Activity_RejectAdjustment" targetRef="EndEvent_Rejected" />
    <bpmn:sequenceFlow id="Flow_Approve_End" sourceRef="Activity_ApplyAdjustment" targetRef="EndEvent_Applied" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_CustomerAdjustmentV1">
    <bpmndi:BPMNPlane id="BPMNPlane_CustomerAdjustmentV1" bpmnElement="customer-adjustment-v1">
      <bpmndi:BPMNShape id="Shape_StartEvent_Submitted" bpmnElement="StartEvent_Submitted"><dc:Bounds x="120" y="180" width="36" height="36" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Activity_CheckerReview" bpmnElement="Activity_CheckerReview"><dc:Bounds x="220" y="158" width="180" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Gateway_CheckerDecision" bpmnElement="Gateway_CheckerDecision" isMarkerVisible="true"><dc:Bounds x="470" y="173" width="50" height="50" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Activity_RequestChanges" bpmnElement="Activity_RequestChanges"><dc:Bounds x="430" y="330" width="180" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Activity_MakerRevise" bpmnElement="Activity_MakerRevise"><dc:Bounds x="220" y="330" width="180" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Activity_RejectAdjustment" bpmnElement="Activity_RejectAdjustment"><dc:Bounds x="590" y="40" width="180" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Activity_ApplyAdjustment" bpmnElement="Activity_ApplyAdjustment"><dc:Bounds x="590" y="260" width="180" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_EndEvent_Applied" bpmnElement="EndEvent_Applied"><dc:Bounds x="840" y="282" width="36" height="36" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_EndEvent_Rejected" bpmnElement="EndEvent_Rejected"><dc:Bounds x="840" y="62" width="36" height="36" /></bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Edge_Flow_Start_CheckerReview" bpmnElement="Flow_Start_CheckerReview"><di:waypoint x="156" y="198" /><di:waypoint x="220" y="198" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Review_DecisionGateway" bpmnElement="Flow_Review_DecisionGateway"><di:waypoint x="400" y="198" /><di:waypoint x="470" y="198" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Decision_RequestChanges" bpmnElement="Flow_Decision_RequestChanges"><di:waypoint x="495" y="223" /><di:waypoint x="495" y="370" /><di:waypoint x="520" y="370" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Decision_Reject" bpmnElement="Flow_Decision_Reject"><di:waypoint x="495" y="173" /><di:waypoint x="495" y="80" /><di:waypoint x="590" y="80" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Decision_Approve" bpmnElement="Flow_Decision_Approve"><di:waypoint x="495" y="223" /><di:waypoint x="495" y="300" /><di:waypoint x="590" y="300" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_RequestChanges_Revise" bpmnElement="Flow_RequestChanges_Revise"><di:waypoint x="430" y="370" /><di:waypoint x="400" y="370" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_RevisionBack_Review" bpmnElement="Flow_RevisionBack_Review"><di:waypoint x="310" y="330" /><di:waypoint x="310" y="238" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Reject_End" bpmnElement="Flow_Reject_End"><di:waypoint x="770" y="80" /><di:waypoint x="840" y="80" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Approve_End" bpmnElement="Flow_Approve_End"><di:waypoint x="770" y="300" /><di:waypoint x="840" y="300" /></bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
