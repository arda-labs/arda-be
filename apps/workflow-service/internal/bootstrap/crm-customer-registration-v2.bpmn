<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" id="Definitions_CRMCustomerRegistrationV2" targetNamespace="https://arda.io.vn/bpmn/customer" exporter="Arda" exporterVersion="2.0">
  <bpmn:error id="Error_ValidationFailed" name="VALIDATION_FAILED" errorCode="VALIDATION_FAILED" />

  <bpmn:process id="crm-customer-registration-v2" name="Đăng ký khách hàng hội viên (v2)" isExecutable="true">
    <bpmn:startEvent id="Start_Submitted" name="Đã gửi duyệt">
      <bpmn:outgoing>Flow_Start_Validate</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:serviceTask id="ST_Validate" name="Kiểm tra hồ sơ">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="crm.customer.register.validate" retries="3" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Start_Validate</bpmn:incoming>
      <bpmn:incoming>Flow_MakerRevise_Validate</bpmn:incoming>
      <bpmn:outgoing>Flow_Validate_Checker</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:boundaryEvent id="Err_Validate" attachedToRef="ST_Validate">
      <bpmn:outgoing>Flow_ValidateError_MakerRevise</bpmn:outgoing>
      <bpmn:errorEventDefinition errorRef="Error_ValidationFailed" />
    </bpmn:boundaryEvent>

    <bpmn:userTask id="UT_CheckerReview" name="Kiểm soát hồ sơ khách hàng">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:assignmentDefinition candidateGroups="CUSTOMER_CHECKER" />
        <zeebe:taskHeaders>
          <zeebe:header key="stepCode" value="checker_review" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Validate_Checker</bpmn:incoming>
      <bpmn:outgoing>Flow_Checker_Decision</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GW_Decision" name="Kết quả kiểm soát" default="Flow_Decision_Supplement">
      <bpmn:incoming>Flow_Checker_Decision</bpmn:incoming>
      <bpmn:outgoing>Flow_Decision_Approve</bpmn:outgoing>
      <bpmn:outgoing>Flow_Decision_Reject</bpmn:outgoing>
      <bpmn:outgoing>Flow_Decision_Supplement</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="UT_MakerRevise" name="Maker bổ sung hồ sơ">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:assignmentDefinition candidateGroups="CUSTOMER_MAKER" />
        <zeebe:taskHeaders>
          <zeebe:header key="stepCode" value="maker_revise" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Decision_Supplement</bpmn:incoming>
      <bpmn:incoming>Flow_ValidateError_MakerRevise</bpmn:incoming>
      <bpmn:outgoing>Flow_MakerRevise_Validate</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:serviceTask id="ST_Execute" name="Kích hoạt hồ sơ khách hàng">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="crm.customer.register.execute" retries="3" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Decision_Approve</bpmn:incoming>
      <bpmn:outgoing>Flow_Execute_End</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="ST_Cancel" name="Từ chối đăng ký">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="crm.customer.register.cancel" retries="3" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Decision_Reject</bpmn:incoming>
      <bpmn:outgoing>Flow_Cancel_End</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="End_Approved" name="Khách hàng được duyệt">
      <bpmn:incoming>Flow_Execute_End</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="End_Rejected" name="Khách hàng bị từ chối">
      <bpmn:incoming>Flow_Cancel_End</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_Start_Validate" sourceRef="Start_Submitted" targetRef="ST_Validate" />
    <bpmn:sequenceFlow id="Flow_Validate_Checker" sourceRef="ST_Validate" targetRef="UT_CheckerReview" />
    <bpmn:sequenceFlow id="Flow_ValidateError_MakerRevise" sourceRef="Err_Validate" targetRef="UT_MakerRevise" />
    <bpmn:sequenceFlow id="Flow_Checker_Decision" sourceRef="UT_CheckerReview" targetRef="GW_Decision" />
    <bpmn:sequenceFlow id="Flow_Decision_Approve" name="Duyệt" sourceRef="GW_Decision" targetRef="ST_Execute">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=reviewDecision = "APPROVE"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Decision_Reject" name="Từ chối" sourceRef="GW_Decision" targetRef="ST_Cancel">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=reviewDecision = "REJECT"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Decision_Supplement" name="Bổ sung" sourceRef="GW_Decision" targetRef="UT_MakerRevise">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=reviewDecision = "REQUEST_CHANGES"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_MakerRevise_Validate" sourceRef="UT_MakerRevise" targetRef="ST_Validate" />
    <bpmn:sequenceFlow id="Flow_Execute_End" sourceRef="ST_Execute" targetRef="End_Approved" />
    <bpmn:sequenceFlow id="Flow_Cancel_End" sourceRef="ST_Cancel" targetRef="End_Rejected" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_CRMCustomerRegistrationV2">
    <bpmndi:BPMNPlane id="BPMNPlane_CRMCustomerRegistrationV2" bpmnElement="crm-customer-registration-v2">
      <bpmndi:BPMNShape id="Shape_Start_Submitted" bpmnElement="Start_Submitted"><dc:Bounds x="120" y="180" width="36" height="36" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_ST_Validate" bpmnElement="ST_Validate"><dc:Bounds x="210" y="158" width="140" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_UT_CheckerReview" bpmnElement="UT_CheckerReview"><dc:Bounds x="400" y="158" width="160" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_GW_Decision" bpmnElement="GW_Decision" isMarkerVisible="true"><dc:Bounds x="620" y="173" width="50" height="50" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_UT_MakerRevise" bpmnElement="UT_MakerRevise"><dc:Bounds x="580" y="320" width="160" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_ST_Execute" bpmnElement="ST_Execute"><dc:Bounds x="730" y="158" width="160" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_ST_Cancel" bpmnElement="ST_Cancel"><dc:Bounds x="730" y="30" width="160" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_End_Approved" bpmnElement="End_Approved"><dc:Bounds x="940" y="180" width="36" height="36" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_End_Rejected" bpmnElement="End_Rejected"><dc:Bounds x="940" y="52" width="36" height="36" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Err_Validate" bpmnElement="Err_Validate"><dc:Bounds x="292" y="120" width="36" height="36" /></bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Edge_Flow_Start_Validate" bpmnElement="Flow_Start_Validate"><di:waypoint x="156" y="198" /><di:waypoint x="210" y="198" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Validate_Checker" bpmnElement="Flow_Validate_Checker"><di:waypoint x="350" y="198" /><di:waypoint x="400" y="198" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Checker_Decision" bpmnElement="Flow_Checker_Decision"><di:waypoint x="560" y="198" /><di:waypoint x="620" y="198" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Decision_Approve" bpmnElement="Flow_Decision_Approve"><di:waypoint x="670" y="198" /><di:waypoint x="730" y="198" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Decision_Reject" bpmnElement="Flow_Decision_Reject"><di:waypoint x="645" y="173" /><di:waypoint x="645" y="70" /><di:waypoint x="730" y="70" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Decision_Supplement" bpmnElement="Flow_Decision_Supplement"><di:waypoint x="645" y="223" /><di:waypoint x="645" y="360" /><di:waypoint x="660" y="360" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_MakerRevise_Validate" bpmnElement="Flow_MakerRevise_Validate"><di:waypoint x="580" y="360" /><di:waypoint x="280" y="360" /><di:waypoint x="280" y="238" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_ValidateError_MakerRevise" bpmnElement="Flow_ValidateError_MakerRevise"><di:waypoint x="310" y="156" /><di:waypoint x="310" y="280" /><di:waypoint x="660" y="320" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Execute_End" bpmnElement="Flow_Execute_End"><di:waypoint x="890" y="198" /><di:waypoint x="940" y="198" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Cancel_End" bpmnElement="Flow_Cancel_End"><di:waypoint x="890" y="70" /><di:waypoint x="940" y="70" /></bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
