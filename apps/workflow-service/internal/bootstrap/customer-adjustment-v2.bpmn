<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" id="Definitions_CustomerAdjustmentV2" targetNamespace="https://arda.io.vn/bpmn/customer" exporter="Arda" exporterVersion="2.0">
  <bpmn:process id="customer-adjustment-v2" name="Dieu chinh ho so khach hang (v2)" isExecutable="true">
    <bpmn:startEvent id="Start_Submitted" name="Gui dieu chinh">
      <bpmn:outgoing>Flow_Start_CheckerReview</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:userTask id="UT_CheckerReview" name="Kiem soat dieu chinh ho so">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:assignmentDefinition candidateGroups="CUSTOMER_CHECKER" />
        <zeebe:taskHeaders>
          <zeebe:header key="stepCode" value="checker_review" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Start_CheckerReview</bpmn:incoming>
      <bpmn:incoming>Flow_RevisionBack_Review</bpmn:incoming>
      <bpmn:outgoing>Flow_Review_DecisionGateway</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GW_CheckerDecision" name="Quyet dinh kiem soat" default="Flow_Decision_RequestChanges">
      <bpmn:incoming>Flow_Review_DecisionGateway</bpmn:incoming>
      <bpmn:outgoing>Flow_Decision_RequestChanges</bpmn:outgoing>
      <bpmn:outgoing>Flow_Decision_Reject</bpmn:outgoing>
      <bpmn:outgoing>Flow_Decision_Approve</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="UT_MakerRevise" name="Maker bo sung dieu chinh">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:assignmentDefinition candidateGroups="CUSTOMER_MAKER" />
        <zeebe:taskHeaders>
          <zeebe:header key="stepCode" value="maker_revise" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Decision_RequestChanges</bpmn:incoming>
      <bpmn:outgoing>Flow_RevisionBack_Review</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:serviceTask id="ST_RejectAdjustment" name="Tu choi dieu chinh">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="crm.reject_customer" retries="3" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Decision_Reject</bpmn:incoming>
      <bpmn:outgoing>Flow_Reject_End</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="ST_ApplyAdjustment" name="Ap dung dieu chinh ho so">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="crm.approve_customer" retries="3" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Decision_Approve</bpmn:incoming>
      <bpmn:outgoing>Flow_Approve_End</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="End_Applied" name="Dieu chinh duoc duyet">
      <bpmn:incoming>Flow_Approve_End</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="End_Rejected" name="Dieu chinh bi tu choi">
      <bpmn:incoming>Flow_Reject_End</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_Start_CheckerReview" sourceRef="Start_Submitted" targetRef="UT_CheckerReview" />
    <bpmn:sequenceFlow id="Flow_Review_DecisionGateway" sourceRef="UT_CheckerReview" targetRef="GW_CheckerDecision" />
    <bpmn:sequenceFlow id="Flow_Decision_RequestChanges" name="Bo sung" sourceRef="GW_CheckerDecision" targetRef="UT_MakerRevise">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=reviewDecision = "REQUEST_CHANGES"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Decision_Reject" name="Tu choi" sourceRef="GW_CheckerDecision" targetRef="ST_RejectAdjustment">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=reviewDecision = "REJECT"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Decision_Approve" name="Duyet" sourceRef="GW_CheckerDecision" targetRef="ST_ApplyAdjustment">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=reviewDecision = "APPROVE"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_RevisionBack_Review" sourceRef="UT_MakerRevise" targetRef="UT_CheckerReview" />
    <bpmn:sequenceFlow id="Flow_Reject_End" sourceRef="ST_RejectAdjustment" targetRef="End_Rejected" />
    <bpmn:sequenceFlow id="Flow_Approve_End" sourceRef="ST_ApplyAdjustment" targetRef="End_Applied" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_CustomerAdjustmentV2">
    <bpmndi:BPMNPlane id="BPMNPlane_CustomerAdjustmentV2" bpmnElement="customer-adjustment-v2">
      <bpmndi:BPMNShape id="Shape_Start_Submitted" bpmnElement="Start_Submitted"><dc:Bounds x="120" y="180" width="36" height="36" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_UT_CheckerReview" bpmnElement="UT_CheckerReview"><dc:Bounds x="220" y="158" width="180" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_GW_CheckerDecision" bpmnElement="GW_CheckerDecision" isMarkerVisible="true"><dc:Bounds x="470" y="173" width="50" height="50" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_UT_MakerRevise" bpmnElement="UT_MakerRevise"><dc:Bounds x="220" y="330" width="180" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_ST_RejectAdjustment" bpmnElement="ST_RejectAdjustment"><dc:Bounds x="590" y="40" width="180" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_ST_ApplyAdjustment" bpmnElement="ST_ApplyAdjustment"><dc:Bounds x="590" y="260" width="180" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_End_Applied" bpmnElement="End_Applied"><dc:Bounds x="840" y="282" width="36" height="36" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_End_Rejected" bpmnElement="End_Rejected"><dc:Bounds x="840" y="62" width="36" height="36" /></bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Edge_Flow_Start_CheckerReview" bpmnElement="Flow_Start_CheckerReview"><di:waypoint x="156" y="198" /><di:waypoint x="220" y="198" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Review_DecisionGateway" bpmnElement="Flow_Review_DecisionGateway"><di:waypoint x="400" y="198" /><di:waypoint x="470" y="198" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Decision_RequestChanges" bpmnElement="Flow_Decision_RequestChanges"><di:waypoint x="495" y="223" /><di:waypoint x="495" y="370" /><di:waypoint x="400" y="370" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Decision_Reject" bpmnElement="Flow_Decision_Reject"><di:waypoint x="495" y="173" /><di:waypoint x="495" y="80" /><di:waypoint x="590" y="80" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Decision_Approve" bpmnElement="Flow_Decision_Approve"><di:waypoint x="495" y="223" /><di:waypoint x="495" y="300" /><di:waypoint x="590" y="300" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_RevisionBack_Review" bpmnElement="Flow_RevisionBack_Review"><di:waypoint x="310" y="330" /><di:waypoint x="310" y="238" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Reject_End" bpmnElement="Flow_Reject_End"><di:waypoint x="770" y="80" /><di:waypoint x="840" y="80" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Approve_End" bpmnElement="Flow_Approve_End"><di:waypoint x="770" y="300" /><di:waypoint x="840" y="300" /></bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
