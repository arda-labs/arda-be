<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" id="Definitions_CustomerRegistrationV1" targetNamespace="https://arda.io.vn/bpmn/customer" exporter="Arda" exporterVersion="1.0">
  <bpmn:process id="customer-registration-v1" name="Đăng ký khách hàng hội viên" isExecutable="true">
    <bpmn:startEvent id="StartEvent_Submitted" name="Gửi đăng ký">
      <bpmn:outgoing>Flow_Start_MarkSubmitted</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:serviceTask id="Activity_MarkSubmitted" name="Khóa nháp và chuyển chờ duyệt">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="crm.mark_customer_submitted" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Start_MarkSubmitted</bpmn:incoming>
      <bpmn:outgoing>Flow_MarkSubmitted_CheckDuplicate</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="Activity_CheckDuplicate" name="Kiểm tra trùng định danh">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="crm.check_customer_duplicate" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_MarkSubmitted_CheckDuplicate</bpmn:incoming>
      <bpmn:outgoing>Flow_CheckDuplicate_DuplicateGateway</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:exclusiveGateway id="Gateway_DuplicateFound" name="Có trùng khách hàng?">
      <bpmn:incoming>Flow_CheckDuplicate_DuplicateGateway</bpmn:incoming>
      <bpmn:outgoing>Flow_Duplicate_RequestChanges</bpmn:outgoing>
      <bpmn:outgoing>Flow_NoDuplicate_Review</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:serviceTask id="Activity_CheckerReview" name="Kiểm soát hồ sơ khách hàng">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="workflow.customer_checker_review" />
        <zeebe:taskHeaders>
          <zeebe:header key="candidateRole" value="CUSTOMER_CHECKER" />
          <zeebe:header key="formKey" value="customer-registration-review" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_NoDuplicate_Review</bpmn:incoming>
      <bpmn:incoming>Flow_RevisionBack_Review</bpmn:incoming>
      <bpmn:outgoing>Flow_Review_DecisionGateway</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:exclusiveGateway id="Gateway_CheckerDecision" name="Quyết định kiểm soát">
      <bpmn:incoming>Flow_Review_DecisionGateway</bpmn:incoming>
      <bpmn:outgoing>Flow_Decision_RequestChanges</bpmn:outgoing>
      <bpmn:outgoing>Flow_Decision_Reject</bpmn:outgoing>
      <bpmn:outgoing>Flow_Decision_RiskGateway</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:serviceTask id="Activity_RequestChanges" name="Yêu cầu bổ sung hồ sơ">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="crm.request_customer_changes" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Duplicate_RequestChanges</bpmn:incoming>
      <bpmn:incoming>Flow_Decision_RequestChanges</bpmn:incoming>
      <bpmn:incoming>Flow_Risk_RequestChanges</bpmn:incoming>
      <bpmn:outgoing>Flow_RequestChanges_Revise</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="Activity_MakerRevise" name="Maker bổ sung thông tin">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="workflow.customer_maker_revise" />
        <zeebe:taskHeaders>
          <zeebe:header key="candidateRole" value="CUSTOMER_MAKER" />
          <zeebe:header key="formKey" value="customer-registration-revise" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_RequestChanges_Revise</bpmn:incoming>
      <bpmn:outgoing>Flow_RevisionBack_Review</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="Activity_RejectCustomer" name="Từ chối đăng ký">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="crm.reject_customer" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Decision_Reject</bpmn:incoming>
      <bpmn:incoming>Flow_Risk_Reject</bpmn:incoming>
      <bpmn:outgoing>Flow_Reject_End</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:exclusiveGateway id="Gateway_RiskRequired" name="Cần rà soát rủi ro?">
      <bpmn:incoming>Flow_Decision_RiskGateway</bpmn:incoming>
      <bpmn:outgoing>Flow_RiskRequired_RiskReview</bpmn:outgoing>
      <bpmn:outgoing>Flow_NoRisk_Approve</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:serviceTask id="Activity_RiskReview" name="Rà soát rủi ro">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="workflow.customer_risk_review" />
        <zeebe:taskHeaders>
          <zeebe:header key="candidateRole" value="CUSTOMER_RISK_CHECKER" />
          <zeebe:header key="formKey" value="customer-risk-review" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_RiskRequired_RiskReview</bpmn:incoming>
      <bpmn:outgoing>Flow_RiskReview_DecisionGateway</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:exclusiveGateway id="Gateway_RiskDecision" name="Quyết định rủi ro">
      <bpmn:incoming>Flow_RiskReview_DecisionGateway</bpmn:incoming>
      <bpmn:outgoing>Flow_Risk_RequestChanges</bpmn:outgoing>
      <bpmn:outgoing>Flow_Risk_Reject</bpmn:outgoing>
      <bpmn:outgoing>Flow_Risk_Approve</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:serviceTask id="Activity_ApproveCustomer" name="Kích hoạt hồ sơ khách hàng">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="crm.approve_customer" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_NoRisk_Approve</bpmn:incoming>
      <bpmn:incoming>Flow_Risk_Approve</bpmn:incoming>
      <bpmn:outgoing>Flow_Approve_Notify</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="Activity_NotifyResult" name="Thông báo kết quả">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="notification.customer_registration_result" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Approve_Notify</bpmn:incoming>
      <bpmn:outgoing>Flow_Notify_EndApproved</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="EndEvent_Approved" name="Khách hàng được duyệt">
      <bpmn:incoming>Flow_Notify_EndApproved</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_Rejected" name="Khách hàng bị từ chối">
      <bpmn:incoming>Flow_Reject_End</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_Start_MarkSubmitted" sourceRef="StartEvent_Submitted" targetRef="Activity_MarkSubmitted" />
    <bpmn:sequenceFlow id="Flow_MarkSubmitted_CheckDuplicate" sourceRef="Activity_MarkSubmitted" targetRef="Activity_CheckDuplicate" />
    <bpmn:sequenceFlow id="Flow_CheckDuplicate_DuplicateGateway" sourceRef="Activity_CheckDuplicate" targetRef="Gateway_DuplicateFound" />
    <bpmn:sequenceFlow id="Flow_Duplicate_RequestChanges" name="Có" sourceRef="Gateway_DuplicateFound" targetRef="Activity_RequestChanges">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=duplicateFound = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_NoDuplicate_Review" name="Không" sourceRef="Gateway_DuplicateFound" targetRef="Activity_CheckerReview">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=duplicateFound != true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Review_DecisionGateway" sourceRef="Activity_CheckerReview" targetRef="Gateway_CheckerDecision" />
    <bpmn:sequenceFlow id="Flow_Decision_RequestChanges" name="Bổ sung" sourceRef="Gateway_CheckerDecision" targetRef="Activity_RequestChanges">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=reviewDecision = "REQUEST_CHANGES"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Decision_Reject" name="Từ chối" sourceRef="Gateway_CheckerDecision" targetRef="Activity_RejectCustomer">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=reviewDecision = "REJECT"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Decision_RiskGateway" name="Duyệt" sourceRef="Gateway_CheckerDecision" targetRef="Gateway_RiskRequired">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=reviewDecision = "APPROVE"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_RequestChanges_Revise" sourceRef="Activity_RequestChanges" targetRef="Activity_MakerRevise" />
    <bpmn:sequenceFlow id="Flow_RevisionBack_Review" sourceRef="Activity_MakerRevise" targetRef="Activity_CheckerReview" />
    <bpmn:sequenceFlow id="Flow_RiskRequired_RiskReview" name="Có" sourceRef="Gateway_RiskRequired" targetRef="Activity_RiskReview">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=riskLevel = "HIGH" or riskLevel = "VERY_HIGH"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_NoRisk_Approve" name="Không" sourceRef="Gateway_RiskRequired" targetRef="Activity_ApproveCustomer">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=riskLevel != "HIGH" and riskLevel != "VERY_HIGH"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_RiskReview_DecisionGateway" sourceRef="Activity_RiskReview" targetRef="Gateway_RiskDecision" />
    <bpmn:sequenceFlow id="Flow_Risk_RequestChanges" name="Bổ sung" sourceRef="Gateway_RiskDecision" targetRef="Activity_RequestChanges">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=riskDecision = "REQUEST_CHANGES"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Risk_Reject" name="Từ chối" sourceRef="Gateway_RiskDecision" targetRef="Activity_RejectCustomer">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=riskDecision = "REJECT"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Risk_Approve" name="Duyệt" sourceRef="Gateway_RiskDecision" targetRef="Activity_ApproveCustomer">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=riskDecision = "APPROVE"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Approve_Notify" sourceRef="Activity_ApproveCustomer" targetRef="Activity_NotifyResult" />
    <bpmn:sequenceFlow id="Flow_Notify_EndApproved" sourceRef="Activity_NotifyResult" targetRef="EndEvent_Approved" />
    <bpmn:sequenceFlow id="Flow_Reject_End" sourceRef="Activity_RejectCustomer" targetRef="EndEvent_Rejected" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_CustomerRegistrationV1">
    <bpmndi:BPMNPlane id="BPMNPlane_CustomerRegistrationV1" bpmnElement="customer-registration-v1">
      <bpmndi:BPMNShape id="Shape_StartEvent_Submitted" bpmnElement="StartEvent_Submitted"><dc:Bounds x="120" y="180" width="36" height="36" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Activity_MarkSubmitted" bpmnElement="Activity_MarkSubmitted"><dc:Bounds x="210" y="158" width="140" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Activity_CheckDuplicate" bpmnElement="Activity_CheckDuplicate"><dc:Bounds x="400" y="158" width="160" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Gateway_DuplicateFound" bpmnElement="Gateway_DuplicateFound" isMarkerVisible="true"><dc:Bounds x="620" y="173" width="50" height="50" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Activity_CheckerReview" bpmnElement="Activity_CheckerReview"><dc:Bounds x="730" y="158" width="160" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Gateway_CheckerDecision" bpmnElement="Gateway_CheckerDecision" isMarkerVisible="true"><dc:Bounds x="950" y="173" width="50" height="50" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Activity_RequestChanges" bpmnElement="Activity_RequestChanges"><dc:Bounds x="730" y="330" width="160" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Activity_MakerRevise" bpmnElement="Activity_MakerRevise"><dc:Bounds x="500" y="330" width="160" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Gateway_RiskRequired" bpmnElement="Gateway_RiskRequired" isMarkerVisible="true"><dc:Bounds x="1060" y="173" width="50" height="50" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Activity_RiskReview" bpmnElement="Activity_RiskReview"><dc:Bounds x="1150" y="300" width="160" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Gateway_RiskDecision" bpmnElement="Gateway_RiskDecision" isMarkerVisible="true"><dc:Bounds x="1370" y="315" width="50" height="50" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Activity_RejectCustomer" bpmnElement="Activity_RejectCustomer"><dc:Bounds x="1150" y="30" width="160" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Activity_ApproveCustomer" bpmnElement="Activity_ApproveCustomer"><dc:Bounds x="1450" y="158" width="160" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Activity_NotifyResult" bpmnElement="Activity_NotifyResult"><dc:Bounds x="1660" y="158" width="160" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_EndEvent_Approved" bpmnElement="EndEvent_Approved"><dc:Bounds x="1880" y="180" width="36" height="36" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_EndEvent_Rejected" bpmnElement="EndEvent_Rejected"><dc:Bounds x="1370" y="52" width="36" height="36" /></bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Edge_Flow_Start_MarkSubmitted" bpmnElement="Flow_Start_MarkSubmitted"><di:waypoint x="156" y="198" /><di:waypoint x="210" y="198" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_MarkSubmitted_CheckDuplicate" bpmnElement="Flow_MarkSubmitted_CheckDuplicate"><di:waypoint x="350" y="198" /><di:waypoint x="400" y="198" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_CheckDuplicate_DuplicateGateway" bpmnElement="Flow_CheckDuplicate_DuplicateGateway"><di:waypoint x="560" y="198" /><di:waypoint x="620" y="198" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Duplicate_RequestChanges" bpmnElement="Flow_Duplicate_RequestChanges"><di:waypoint x="645" y="223" /><di:waypoint x="645" y="370" /><di:waypoint x="730" y="370" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_NoDuplicate_Review" bpmnElement="Flow_NoDuplicate_Review"><di:waypoint x="670" y="198" /><di:waypoint x="730" y="198" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Review_DecisionGateway" bpmnElement="Flow_Review_DecisionGateway"><di:waypoint x="890" y="198" /><di:waypoint x="950" y="198" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Decision_RequestChanges" bpmnElement="Flow_Decision_RequestChanges"><di:waypoint x="975" y="223" /><di:waypoint x="975" y="370" /><di:waypoint x="890" y="370" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Decision_Reject" bpmnElement="Flow_Decision_Reject"><di:waypoint x="975" y="173" /><di:waypoint x="975" y="70" /><di:waypoint x="1150" y="70" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Decision_RiskGateway" bpmnElement="Flow_Decision_RiskGateway"><di:waypoint x="1000" y="198" /><di:waypoint x="1060" y="198" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_RequestChanges_Revise" bpmnElement="Flow_RequestChanges_Revise"><di:waypoint x="730" y="370" /><di:waypoint x="660" y="370" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_RevisionBack_Review" bpmnElement="Flow_RevisionBack_Review"><di:waypoint x="580" y="330" /><di:waypoint x="580" y="260" /><di:waypoint x="810" y="260" /><di:waypoint x="810" y="238" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_RiskRequired_RiskReview" bpmnElement="Flow_RiskRequired_RiskReview"><di:waypoint x="1085" y="223" /><di:waypoint x="1085" y="340" /><di:waypoint x="1150" y="340" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_NoRisk_Approve" bpmnElement="Flow_NoRisk_Approve"><di:waypoint x="1110" y="198" /><di:waypoint x="1450" y="198" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_RiskReview_DecisionGateway" bpmnElement="Flow_RiskReview_DecisionGateway"><di:waypoint x="1310" y="340" /><di:waypoint x="1370" y="340" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Risk_RequestChanges" bpmnElement="Flow_Risk_RequestChanges"><di:waypoint x="1395" y="365" /><di:waypoint x="1395" y="430" /><di:waypoint x="810" y="430" /><di:waypoint x="810" y="410" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Risk_Reject" bpmnElement="Flow_Risk_Reject"><di:waypoint x="1395" y="315" /><di:waypoint x="1395" y="70" /><di:waypoint x="1310" y="70" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Risk_Approve" bpmnElement="Flow_Risk_Approve"><di:waypoint x="1420" y="340" /><di:waypoint x="1530" y="340" /><di:waypoint x="1530" y="238" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Approve_Notify" bpmnElement="Flow_Approve_Notify"><di:waypoint x="1610" y="198" /><di:waypoint x="1660" y="198" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Notify_EndApproved" bpmnElement="Flow_Notify_EndApproved"><di:waypoint x="1820" y="198" /><di:waypoint x="1880" y="198" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Reject_End" bpmnElement="Flow_Reject_End"><di:waypoint x="1310" y="70" /><di:waypoint x="1370" y="70" /></bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
